# ===== DeepSeek API 配置 =====
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# ===== 成本控制 =====
# DeepSeek 价格极低（约为 GPT-3.5 的 1/10）
# 参考价格：输入 $0.014 / 1M tokens，输出 $0.028 / 1M tokens
# 换算：输入 $0.000014 / 1K tokens，输出 $0.000028 / 1K tokens
COST_PER_1K_INPUT=0.000014
COST_PER_1K_OUTPUT=0.000028

# ===== Token 限制 =====
# DeepSeek 上下文窗口 64K tokens，建议保守设置
MAX_TOTAL_TOKENS_PER_CONVERSATION=16000    # 单轮对话总 Token 上限
MAX_TOKENS_PER_REQUEST=4000                # 单次 API 请求输出上限

# ===== 超时与重试 =====
REQUEST_TIMEOUT=60                         # 单次请求超时（秒）
MAX_RETRIES=3                              # 请求失败最大重试次数
RETRY_DELAY=1.0                            # 重试间隔（秒）

# ===== 模型温度 =====
LLM_TEMPERATURE_PARSER=0.1
LLM_TEMPERATURE_MATCHER=0.3
LLM_TEMPERATURE_RISK=0.2
LLM_TEMPERATURE_OFFER=0.5